POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_PORT=5000

# Wildberries API Token (получить в кабинете поставщика WB)
WB_API_TOKEN=your_token_here

# Cron schedule (по умолчанию каждый час в 00 минут)
CRON_SCHEDULE=0 * * * *

# Google Apps Script Webhook URL
# Инструкция по настройке в README.md (раздел "Настройка Google Sheets")
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
